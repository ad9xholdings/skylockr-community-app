# SkyLockr Community App - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DISCOURSE CONFIGURATION
# =============================================================================

# Hostname for your Discourse instance
DISCOURSE_HOSTNAME=community.skylockr.com

# Developer emails (comma-separated)
DEVELOPER_EMAILS=admin@skylockr.com

# Secret key base (generate with: openssl rand -hex 64)
SECRET_KEY_BASE=your_secret_key_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

DB_PASSWORD=skylockr_secure_2026

# =============================================================================
# SMTP CONFIGURATION (for email)
# =============================================================================

SMTP_ADDRESS=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password

# =============================================================================
# S3 CONFIGURATION (optional, for file uploads)
# =============================================================================

S3_ENABLED=false
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=us-east-1
S3_BUCKET=skylockr-uploads

# =============================================================================
# XRP LEDGER CONFIGURATION
# =============================================================================

# Network: mainnet, testnet, or devnet
XRP_NETWORK=mainnet
XRP_RPC=https://s1.ripple.com:51234
XRP_WS_URL=wss://s1.ripple.com

# XUMM Wallet API credentials
# Get these from https://apps.xumm.dev
XUMM_API_KEY=your_xumm_api_key
XUMM_API_SECRET=your_xumm_api_secret

# JWT Secret for WebSocket auth
JWT_SECRET=your_jwt_secret_here

# =============================================================================
# JAMZIA SSO CONFIGURATION
# =============================================================================

JAMZIA_SSO=https://auth.jamzia.com
JAMZIA_API_KEY=your_jamzia_api_key
JAMZIA_API_SECRET=your_jamzia_api_secret

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

GRAFANA_PASSWORD=admin

# =============================================================================
# MOBILE APP CONFIGURATION
# =============================================================================

KEYSTORE_PASSWORD=your_keystore_password
KEYSTORE_ALIAS_PASSWORD=your_alias_password

# =============================================================================
# DISCOURSE SETTINGS
# =============================================================================

# Number of Unicorn workers
UNICORN_WORKERS=4

# Number of Sidekiq workers
UNICORN_SIDEKIQS=2

# Rails environment
RAILS_ENV=production

# Seed database on first run
SEED_DATABASE=true
